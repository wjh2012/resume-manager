# Database (로컬: Docker PostgreSQL / prod: Supabase)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/resume_manager

# Direct DB connection (prod Vercel 전용 — Prisma CLI가 migration 시 사용)
# 로컬 Docker에서는 불필요 (pooler 없음)
# DIRECT_URL=postgresql://postgres.xxx:password@db.xxx.supabase.co:5432/postgres

# Supabase (Auth/Storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenAI (임베딩 전용 - 사용자 AI 설정과 별도)
OPENAI_API_KEY=
